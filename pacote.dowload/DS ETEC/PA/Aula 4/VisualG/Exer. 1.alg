algoritmo "EX 01"

var
   Nome, sexo: caracter
   idade :inteiro
   
inicio
  Escreva("Qual é seu nome? ")
  Leia(nome)
  Escreva("Qual seu sexo? ")
  Leia(sexo)
  Escreva("Qual sua idade? ")
  Leia(idade)
  Escreval("O seu nome é: ", nome)
  Escreval("O seu sexo é: ", sexo)
  Escreval("A sua idade é: ", idade)
fimalgoritmo
